# Copy this to .env and fill in your values

# Required: your actual SOAP endpoint URL
SOAP_ENDPOINT=http://your-server/uniface/wsdl/CSYV1000

# Port to run the wrapper on (cloud hosts set this automatically)
PORT=3000

# Optional: set a secret key to protect your wrapper
# If set, all requests must include header: x-api-key: <value>
API_KEY=
